# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/carbon_footprint_db?schema=public"

# JWT - Use strong random secrets in production (min 64 chars)
JWT_ACCESS_SECRET=your_super_secret_access_key_min_64_chars_replace_in_production_now
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_replace_in_production_now
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
